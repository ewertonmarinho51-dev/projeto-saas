# ============================================================
# ONDE INSERIR A CHAVE DA API (opção recomendada)
#
# 1. Copie este arquivo para:  .streamlit/secrets.toml
#    (o secrets.toml está no .gitignore e NUNCA deve ser commitado)
# 2. Cole sua chave do Google AI Studio (https://aistudio.google.com/apikey)
#
# Alternativa: exporte a variável de ambiente GOOGLE_API_KEY
#   Linux/macOS:  export GOOGLE_API_KEY="sua-chave"
#   Windows:      set GOOGLE_API_KEY=sua-chave
# ============================================================

# MOTOR PRINCIPAL — OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY = "sk-proj-cole-sua-chave-aqui"
# Opcional: modelo OpenAI (padrão: gpt-5-mini)
# OPENAI_MODEL = "gpt-5"

# FALLBACK — Google Gemini (https://aistudio.google.com/apikey)
# Usado se a OpenAI falhar; opcional.
# GOOGLE_API_KEY = "cole-sua-chave-aqui"
# Opcional: modelo Gemini (padrão: gemini-2.5-flash)
# GEMINI_MODEL = "gemini-2.5-pro"

# ------------------------------------------------------------
# BANCO DE DADOS (Supabase) — persistência dos processos
# Painel do projeto ➜ Settings ➜ API:
#   SUPABASE_URL = "Project URL"
#   SUPABASE_KEY = "chave publishable (sb_publishable_...) ou anon"
# Sem essas chaves a aplicação funciona normalmente, apenas sem
# salvar/retomar processos.
# ------------------------------------------------------------
SUPABASE_URL = "https://SEU-PROJETO.supabase.co"
SUPABASE_KEY = "sua-chave-publishable-ou-anon"
